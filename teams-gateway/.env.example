# Teams gateway — environment (Phase-1.3 skeleton).
# Copy to .env and fill in. Per env-var discipline: keep this file in sync with config.ts.

# --- HTTP ---
PORT=3024
# Comma-separated bind hosts (discord parity). Default 127.0.0.1.
# In production the public bot paths sit behind a tunnel; bind accordingly.
HOST=127.0.0.1

# --- AMP / Maestro ---
# Maestro base URL. In a worker container this is the host mesh URL ($AMP_MAESTRO_URL);
# config.ts also accepts AMP_MAESTRO_URL as a fallback.
AIMAESTRO_URL=http://127.0.0.1:23000
# AMP org/tenant to register bot identities under. REQUIRED on a tenant-scoped
# Maestro (e.g. 'example') — otherwise bootstrap falls back to the discovered
# provider tenant ('default'), which such a Maestro rejects with a 400. Matches
# the discord-gateway AMP_TENANT convention.
AMP_TENANT=example

# --- Auth (fail-closed) ---
# Bearer token for the management API (/api/admin/*). REQUIRED — an empty value
# throws at startup (no bypass-when-empty). The public /api/<slug>/messages bot
# paths are Bot-Service-JWT-authed, NOT by this token.
ADMIN_TOKEN=

# --- Operator trust (tenant-scoped, red-team §0.2) ---
# Format: tenantId:aadObjectId[,tenantId:aadObjectId,...]
# MUST be (tenantId, aadObjectId) pairs — never a bare aadObjectId.
OPERATOR_AAD_OBJECT_IDS=

# --- Bot registry (PLAN §6) ---
# JSON array, one block per Azure AD app registration. `agentName` is optional
# (defaults to teams-<slug>-bot). `slug` must be unique and not reserved
# (admin/health/api). Each appId/agentName/defaultAgent must be unique.
# NOTE: single-quote the value — start.sh sources this file, and an unquoted
# JSON value has its double-quotes stripped by bash (invalid JSON at startup).
TEAMS_BOTS='[{"slug":"maestro","appId":"00000000-0000-0000-0000-000000000000","appPassword":"REPLACE_ME","appTenantId":"11111111-1111-1111-1111-111111111111","defaultAgent":"ops-agent@example.aimaestro.local"}]'

# --- Bootstrap mode ---
# TEAMS_DRY_RUN=1 resolves + logs the bot plan with NO network register (used for
# the skeleton boot smoke). Unset/0 performs the real per-bot AMP registration
# against AIMAESTRO_URL — this mints persistent live-directory identities and is a
# DEPLOY-TIME, COORDINATED change (Phase 5/6), not for casual local boots.
TEAMS_DRY_RUN=1

# --- Outbound delivery (Phase 3) ---
# Inbox-poll cadence in ms (default 3000). The poller scans each registered bot's
# AMP inbox for agent replies and posts them back under that bot.
POLL_INTERVAL_MS=3000
# Render replies as markdown (default) or plain text. Set 0/false for plain.
TEAMS_MARKDOWN=1

# --- Attachments (w3) ---
# Gateway-side caps, enforced fail-fast BEFORE Maestro's own 25MB cap + magic-byte
# sniff at confirm. VALUES are a Whistler-owned security decision; defaults are safe.
# Per-attachment byte ceiling (default 26214400 = 25MB, matches AMP_MAX_ATTACHMENT_BYTES).
TEAMS_ATTACH_MAX_BYTES=26214400
# Per-message attachment count cap; extras are dropped + logged (default 10).
TEAMS_ATTACH_MAX_COUNT=10
# Comma-separated, lower-cased content-type substrings ALWAYS rejected gateway-side
# (defense-in-depth on known-dangerous executables; Maestro still sniffs at confirm).
# Unset = built-in executable deny-list; set empty to disable; set a list to override.
TEAMS_ATTACH_DENY_TYPES=

# --- Thread-store persistence (Phase 3) ---
# JSON snapshot so a reply that lands after a restart can still resolve its Teams
# conversation. Default: ~/.agent-messaging/teams-gateway/thread-store.json.
THREAD_STORE_PATH=
# Periodic snapshot cadence in ms (crash-safety floor; default 60000). The graceful
# SIGTERM/SIGINT path also snapshots once on the way down.
SNAPSHOT_INTERVAL_MS=60000

# --- User directory ---
# Resolver cache TTL in ms (default 300000 = 5 min).
CACHE_USER_TTL_MS=300000

# --- Misc ---
DEBUG=
