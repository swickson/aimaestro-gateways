# Discord Bot Configuration (required)
DISCORD_BOT_TOKEN=your-discord-bot-token

# Gateway Configuration
PORT=3023
# Bind address(es) for the management HTTP server. Comma-separated to listen
# on multiple interfaces (e.g. loopback + tailscale). Default: 127.0.0.1.
# HOST=127.0.0.1,100.81.151.18

# AI Maestro Configuration
# AIMAESTRO_API=http://127.0.0.1:23000
# DEFAULT_AGENT=my-agent
# HOST_ID=my-host

# Security: Operator Discord user IDs (comma-separated, full trust - no content wrapping)
# OPERATOR_DISCORD_IDS=000000000000000000

# Watch webhooks: route messages posted by specific webhooks to a fixed agent
# in monitor mode (no @mention required, no Discord reply, no threadStore entry).
# Format: channelId:webhookId:targetAgent[,channelId:webhookId:targetAgent,...]
# WATCH_WEBHOOKS=1414788201499070494:1494477100311253033:ops-exec-safety@n4x-corp.aimaestro.local

# Drop duplicate watch-webhook messages with identical content seen within this
# window (ms). Some upstream webhook producers double-emit events. Set to 0 to
# disable. Default: 60000 (60s).
# WATCH_DEDUP_WINDOW_MS=60000

# Admin API token (REQUIRED — gateway refuses to start without it).
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=your-admin-token

# Cache TTLs (milliseconds)
# CACHE_AGENT_TTL_MS=300000
# CACHE_HOSTS_TTL_MS=60000

# Polling
# POLL_INTERVAL_MS=2000
# POLL_TIMEOUT_MS=5000

# Development
# DEBUG=true
