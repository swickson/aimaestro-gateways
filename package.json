{
  "name": "aimaestro-gateways",
  "private": true,
  "workspaces": [
    "packages/common"
  ],
  "scripts": {
    "lint": "eslint '*/src/**/*.ts' 'packages/*/src/**/*.ts'",
    "typecheck:discord": "cd discord-gateway && npx tsc --noEmit",
    "typecheck:slack": "cd slack-gateway && npx tsc --noEmit",
    "typecheck:email": "cd email-gateway && npx tsc --noEmit",
    "typecheck:whatsapp": "cd whatsapp-gateway && npx tsc --noEmit",
    "typecheck:teams": "cd teams-gateway && npx tsc --noEmit",
    "typecheck:common": "cd packages/common && npx tsc --noEmit",
    "typecheck": "npm run typecheck:discord && npm run typecheck:slack && npm run typecheck:email && npm run typecheck:whatsapp && npm run typecheck:teams && npm run typecheck:common",
    "test:discord": "cd discord-gateway && npm test",
    "test:slack": "cd slack-gateway && npm test",
    "test:email": "cd email-gateway && npm test",
    "test:whatsapp": "cd whatsapp-gateway && npm test",
    "test:teams": "cd teams-gateway && npm test",
    "test:common": "cd packages/common && npm test",
    "test": "npm run test:discord && npm run test:slack && npm run test:email && npm run test:whatsapp && npm run test:teams && npm run test:common"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.1"
  }
}
